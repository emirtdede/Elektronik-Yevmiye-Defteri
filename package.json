{
  "name": "elektronik-yevmiye-defteri",
  "version": "1.0.0",
  "description": "Offline-first Electron React SQLite Desktop App",
  "main": "src/main/index.js",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "build:react": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:react && npm run build:electron",
    "test": "vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "electron-log": "^5.4.4",
    "express": "^5.2.1",
    "i18next": "^26.3.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.368.0",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.22.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^2.2.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "playwright": "^1.60.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.8",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  }
}
